<section class="holocall-contacts">
  <header class="holocall-contacts-header">
    <div>
      <div class="holocall-contacts-kicker">Personal Comms Directory</div>
      <h2>HoloCall Contacts</h2>
    </div>
  </header>

  <nav class="holocall-contact-tabs">
    <button type="button" class="{{#if isPersonalTab}}active{{/if}}" data-holocall-contact-tab="personal">Personal</button>
    <button type="button" class="{{#if isGroupTab}}active{{/if}}" data-holocall-contact-tab="group">Group</button>
  </nav>

  <section data-holocall-contact-panel="personal" {{#unless isPersonalTab}}hidden{{/unless}}>
    <ul class="holocall-contacts-list">
      {{#if hasContacts}}
        {{#each contacts}}
          <li>
            <div class="holocall-contact-id">
              <strong>{{name}}</strong>
              <span>{{number}}</span>
            </div>
            <div class="holocall-contact-actions">
              <button type="button" data-holocall-contact-action="call" data-contact-scope="personal" data-contact-id="{{id}}">Call</button>
              <button type="button" data-holocall-contact-action="remove" data-contact-scope="personal" data-contact-id="{{id}}">Remove</button>
            </div>
          </li>
        {{/each}}
      {{else}}
        <li class="holocall-contacts-empty">
          <span>No personal contacts stored.</span>
        </li>
      {{/if}}
    </ul>
  </section>

  <section data-holocall-contact-panel="group" {{#unless isGroupTab}}hidden{{/unless}}>
    <ul class="holocall-contacts-list">
      {{#if hasGroupContacts}}
        {{#each groupContacts}}
          <li>
            <div class="holocall-contact-id">
              <strong>{{name}}</strong>
              <span>{{number}}</span>
            </div>
            <div class="holocall-contact-actions">
              <button type="button" data-holocall-contact-action="call" data-contact-scope="group" data-contact-id="{{id}}">Call</button>
              <button type="button" data-holocall-contact-action="remove" data-contact-scope="group" data-contact-id="{{id}}">Remove</button>
            </div>
          </li>
        {{/each}}
      {{else}}
        <li class="holocall-contacts-empty">
          <span>No group contacts stored.</span>
        </li>
      {{/if}}
    </ul>
  </section>

  <form class="holocall-contacts-form" data-holocall-contacts-form>
    <input type="hidden" name="scope" value="{{activeTab}}">

    <label>
      <span>Name</span>
      <input type="text" name="name" autocomplete="off" required>
    </label>

    <label>
      <span>Number</span>
      <input type="text" name="number" autocomplete="off" required>
    </label>

    <button type="submit">Add Contact</button>
  </form>
</section>
