<section class="pulse-scanner-shell">
  <header class="pulse-scanner-header">
    <div>
      <h2>Pulse Scanner</h2>
      <p>{{#if scene}}{{scene.name}}{{else}}No active scene{{/if}}</p>
    </div>
    <div class="pulse-scanner-header-actions">
      <div class="pulse-scanner-tool-row">
        <button type="button" data-action="new-target"><i class="fa-solid fa-plus"></i> New Target</button>
      </div>
    </div>
  </header>

  <form class="pulse-scanner-item-config" autocomplete="off">
    <label>
      <span>Item Name</span>
      <input type="text" name="scannerItemName" value="{{scannerItem.name}}">
    </label>
    <label>
      <span>Signal</span>
      <select name="scannerItemMode">
        {{#each modeOptions}}
          <option value="{{value}}" {{psOption value ../scannerItem.mode}}>{{label}}</option>
        {{/each}}
      </select>
    </label>
    <label>
      <span>Radius (ft)</span>
      <input type="number" name="scannerItemRadiusFeet" value="{{scannerItem.radiusFeet}}" min="0" step="5">
      <small>For performance, keep scanner radius at 100 ft or less.</small>
    </label>
    <button type="button" data-action="create-scanner-item-config"><i class="fa-solid fa-plus"></i> Create Item</button>
  </form>

  <div class="pulse-scanner-layout">
    <aside class="pulse-scanner-list">
      {{#if hasTargets}}
        {{#each targets}}
          <article class="pulse-scanner-target-card {{#if (psEq ../selectedTarget.id id)}}is-active{{/if}} {{#if isResolved}}is-resolved{{/if}}" data-target-id="{{id}}">
            <div class="pulse-scanner-target-card-main">
              <span class="pulse-scanner-dot" style="--target-color: {{color}};"></span>
              <div>
                <strong>{{label}}</strong>
                <small>{{psModeLabel mode}} - {{psTypeLabel type}} - {{visibility}} - {{status}}{{#if regionName}} - {{regionName}}{{/if}}</small>
              </div>
            </div>
            <div class="pulse-scanner-target-card-actions">
              <button type="button" data-action="reveal-target" data-target-id="{{id}}" title="Reveal to players"><i class="fa-solid fa-eye"></i><span>Reveal</span></button>
              <button type="button" data-action="hide-target" data-target-id="{{id}}" title="Hide from players"><i class="fa-solid fa-eye-slash"></i><span>Hide</span></button>
              <button type="button" data-action="toggle-resolved" data-target-id="{{id}}" title="{{#if isResolved}}Mark active{{else}}Mark resolved or destroyed{{/if}}"><i class="fa-solid {{#if isResolved}}fa-rotate-left{{else}}fa-check{{/if}}"></i><span>{{#if isResolved}}Unresolve{{else}}Resolve{{/if}}</span></button>
              <button type="button" data-action="delete-target" data-target-id="{{id}}" title="Delete target"><i class="fa-solid fa-trash"></i><span>Delete</span></button>
            </div>
          </article>
        {{/each}}
      {{else}}
        <div class="pulse-scanner-empty-state">
          <i class="fa-solid fa-satellite-dish"></i>
          <strong>No scan targets on this scene</strong>
          <span>Draw a Scene Region first, then click New Target to link it.</span>
        </div>
      {{/if}}
    </aside>

    <main class="pulse-scanner-editor">
      {{> "modules/pulse-scanner/templates/target-form.hbs"}}
    </main>
  </div>
</section>
